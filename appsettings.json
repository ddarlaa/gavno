{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "IceBreakerApp": "Debug"
    }
  },
  "AllowedHosts": "*",
  "StorageSettings": {
    "StoragePath": "Storage",
    "FilesPath": "Storage/Files",
    "ThumbnailsPath": "Storage/Thumbnails",
    "TempPath": "Storage/Temp"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=IceBreakerDb;Username=postgres;Password=password123;Port=5432"
  },
  "JwtSettings": {
    "SecretKey": "your-super-secret-key-at-least-32-characters-long",
    "Issuer": "IceBreakerApp",
    "Audience": "IceBreakerAppUsers",
    "AccessTokenExpirationMinutes": 30,
    "RefreshTokenExpirationDays": 7,
    "ClockSkew": "00:05:00",
    "ValidateIssuerSigningKey": true,
    "ValidateIssuer": true,
    "ValidateAudience": true,
    "ValidateLifetime": true,
    "UseKeycloak": false
  },
  "CorsSettings": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5047",
      "https://localhost:7273",
      "http://localhost:4200",
      "https://localhost:4200"
    ],
    "AllowedMethods": [
      "GET",
      "POST",
      "PUT",
      "DELETE",
      "PATCH",
      "OPTIONS"
    ],
    "AllowedHeaders": [
      "Authorization",
      "Content-Type",
      "X-Requested-With",
      "Accept"
    ],
    "AllowCredentials": true,
    "ExposedHeaders": [
      "Content-Disposition"
    ]
  },
  "SwaggerSettings": {
    "EnableSwagger": true,
    "BearerTokenDescription": "JWT Authorization header using the Bearer scheme. Enter 'Bearer' [space] and then your token in the text input below.",
    "BearerFormat": "JWT",
    "IncludeXmlComments": true,
    "Title": "IceBreakerApp API",
    "Version": "v1",
    "Description": "API for IceBreakerApp - Social Q&A Platform"
  },
  "AuthorizationSettings": {
    "DefaultUserRole": "User",
    "RequireEmailConfirmation": false,
    "MaxLoginAttempts": 5,
    "LockoutDuration": "00:15:00",
    "Password": {
      "RequiredLength": 8,
      "RequireUppercase": true,
      "RequireLowercase": true,
      "RequireDigit": true,
      "RequireNonAlphanumeric": true
    }
  },
  "DatabaseSettings": {
    "CommandTimeout": 60,
    "ConnectionTimeout": 30,
    "RetryCount": 3,
    "EnableSensitiveDataLogging": false,
    "EnableDetailedErrors": true,
    "MaxBatchSize": 1000
  },
  "EmailSettings": {
    "Provider": "Mock",
    "FromEmail": "noreply@icebreaker.com",
    "FromName": "IceBreakerApp",
    "Smtp": {
      "Host": "smtp.gmail.com",
      "Port": 587,
      "UseSsl": true,
      "Username": "",
      "Password": ""
    }
  },
  "RateLimiting": {
    "MaxRequestsPerMinute": 100,
    "MaxRequestsPerHour": 1000
  },
  "Keycloak": {
    "Enabled": false,
    "Url": "http://localhost:8080",
    "Realm": "icebreaker-app",
    "ClientId": "icebreaker-api",
    "ClientSecret": "",
    "AdminUsername": "admin",
    "AdminPassword": "",
    "RequireHttpsMetadata": false,
    "SupportedTokens": "Both",
    "CacherealmRoles": true,
    "CacheclientScopes": true,
    "VerifyTokenAudience": false
  },
  "FileValidation": {
    "MaxFileSize": 52428800,
    "MaxTotalSizeMultiple": 104857600,
    "MaxFilesPerRequest": 10,
    "MaxFileNameLength": 255,
    "MinFileNameLength": 1,
    "AllowedExtensions": [
      ".jpg",
      ".jpeg",
      ".png",
      ".gif",
      ".webp",
      ".pdf",
      ".doc",
      ".docx",
      ".xls",
      ".xlsx"
    ]
  }
}