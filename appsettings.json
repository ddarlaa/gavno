{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5000"
      },
      "Https": {
        "Url": "https://localhost:5001"
      }
    }
  },
  "StorageSettings": {
    "StoragePath": "Data"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=IceBreakerAppDb;Username=postgres;Password=your_password;Port=5432"
  },
  "JwtSettings": {
    "SecretKey": "IceBreakerAppJWTSecretKey2024!@#$%^&*()_+-=[]{}|;:,.<>?",
    "Issuer": "IceBreakerApp",
    "Audience": "IceBreakerAppUsers",
    "AccessTokenExpirationMinutes": 30,
    "RefreshTokenExpirationDays": 7
  },
  "EmailSettings": {
    "Provider": "SendGrid",
    "DefaultFromEmail": "noreply@icebreakapp.com",
    "DefaultFromName": "IceBreakerApp"
  },
  "SendGrid": {
    "ApiKey": "YOUR_SENDGRID_API_KEY_HERE",
    "FromEmail": "noreply@icebreakapp.com",
    "FromName": "IceBreakerApp"
  },
  "Mailgun": {
    "ApiKey": "YOUR_MAILGUN_API_KEY_HERE",
    "Domain": "yourdomain.com",
    "FromEmail": "noreply@yourdomain.com"
  },
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": "587",
    "Username": "your-email@gmail.com",
    "Password": "your-app-password",
    "EnableSsl": "true",
    "FromEmail": "your-email@gmail.com",
    "FromName": "IceBreakerApp"
  }
}